# Agenticana v6.0 Secretary Bird Edition 🦅 — .gitignore

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/mcp.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Agentica runtime files ────────────────────────────────────────────────────
# The following contain personal data or local secrets — NEVER commit these
.Agentica/
memory/trajectories/
memory/*.log

# These contain shared team logic (optional to share)
# memory/reasoning-bank/decisions.json
# memory/reasoning-bank/patterns.json

# Exclude only large runtime-generated files
# Generated workspace files (user-specific)
*.code-workspace

# ── Test & coverage outputs ───────────────────────────────────────────────────
coverage/
test-results/

# ── Build ─────────────────────────────────────────────────────────────────────
dist/
build/
